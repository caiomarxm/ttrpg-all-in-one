{
  "log_level": "info",
  "channel": {
    "without_namespace": {
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": false
    }
  },
  "client": {
    "allowed_origins": ["http://localhost:5173", "http://127.0.0.1:5173"],
    "token": {
      "hmac_secret_key": "dev-centrifugo-hmac-secret"
    }
  },
  "http_api": {
    "key": "dev-centrifugo-api-key"
  },
  "broker": {
    "enabled": true,
    "type": "nats",
    "nats": {
      "url": "nats://nats:4222",
      "prefix": "centrifugo"
    }
  }
}
