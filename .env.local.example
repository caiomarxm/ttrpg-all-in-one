### Copy to `.env.local` for local development (never commit secrets).

# Postgres (Compose maps campaigns to 5432 and wiki to 5433 by default)
CAMPAIGNS_DATABASE_URL=postgresql+psycopg://ttrpg:ttrpg@127.0.0.1:5432/campaigns
WIKI_DATABASE_URL=postgresql+psycopg://ttrpg:ttrpg@127.0.0.1:5433/wiki

# NATS (JetStream enabled)
NATS_URL=nats://127.0.0.1:4222

# Centrifugo (must match `infra/centrifugo/config.json` unless you edit both)
CENTRIFUGO_HTTP_URL=http://127.0.0.1:8000
CENTRIFUGO_WS_URL=ws://127.0.0.1:8000/connection/websocket
CENTRIFUGO_HTTP_API_KEY=dev-centrifugo-api-key
CENTRIFUGO_CLIENT_TOKEN_HMAC_SECRET_KEY=dev-centrifugo-hmac-secret

# MinIO (S3-compatible local object storage)
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio-dev-password
MINIO_BUCKET_ASSETS=ttrpg-assets
